# ─── Supabase ────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhb...anon_public_key

# ─── Web Push (VAPID) ────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# Only the PUBLIC key belongs on the client. The private key goes to
# Supabase via `supabase secrets set VAPID_PRIVATE_KEY=...` — never here.
VITE_VAPID_PUBLIC_KEY=BM...public_key_only

# ─── This location ───────────────────────────────────────────────────────
# Run the migration, then copy the row id from `locations` where slug='gbig'.
VITE_LOCATION_ID=
VITE_APP_NAME=GBIG App
VITE_APP_FULL_NAME=Green Bay Indoor Golf
VITE_BOOKING_URL=https://greenbayindoorgolf.com/app-page-booking/

# ─── NEVER set this in a VITE_-prefixed variable ─────────────────────────
# VITE_SUPABASE_SERVICE_ROLE_KEY — bundled into the browser, would grant
# every visitor full DB access. Privileged operations live in Edge
# Functions. See supabase/functions/*.
